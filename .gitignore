# Production / Render local artifacts
.env
.env.*
!.env.example
!.env.sample
*.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Node / Vite frontend
frontend/node_modules/
frontend/dist/
frontend/dist*/
frontend/.vite/
frontend/.cache/
frontend/coverage/
frontend/tsconfig.tsbuildinfo

# Java / Maven backend
backend/target/
backend/.mvn/wrapper/maven-wrapper.jar
*.class
*.jar
*.war
*.ear

# Local databases and generated runtime files
*.db
*.sqlite
*.sqlite3
uploads/
tmp/
temp/

# User-uploaded documents (Vault storage) - never commit real personal files
backend/storage/*
!backend/storage/.gitkeep

# Aiven / DB CA certificates - never commit credentials or certs
*.pem
*.crt
*ca.pem
render-env.txt

# IDE / editor
.idea/
.vscode/
*.iml

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Docker local override files
docker-compose.override.yml
